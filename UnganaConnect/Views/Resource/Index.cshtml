@using UnganaConnect.Models.Resource
@model ResourceLibraryViewModel
@{
    ViewData["Title"] = "Resources";
    var role = Context.Session.GetString("Role");
}

<div class="max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 mb-2">Resources</h1>
                <p class="text-gray-600">Access toolkits, templates, and guides to support your organization</p>
            </div>
            @if (role == "Admin" || role == "Instructor")
            {
                <a href="@Url.Action("Create")" 
                   class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-plus mr-2"></i>Add Resource
                </a>
            }
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-600 mb-1">Total Resources</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Stats.TotalResources</p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-file-text text-blue-600 text-xl"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-600 mb-1">Total Downloads</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Stats.TotalDownloads.ToString("N0")</p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-download text-purple-600 text-xl"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-600 mb-1">This Month</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Stats.ThisMonth</p>
                </div>
                <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-calendar text-orange-600 text-xl"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-600 mb-1">Contributors</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Stats.Contributors</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-users text-green-600 text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="mb-6">
        <form method="get" class="flex flex-col md:flex-row gap-4">
            <div class="flex-1 relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i class="fas fa-search text-gray-400"></i>
                </div>
                <input type="text" 
                       name="search" 
                       class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                       placeholder="Search resources, tags, or authors..." 
                       value="@Model.SearchTerm">
                <input type="hidden" name="category" value="@Model.SelectedCategory">
            </div>
            <button type="submit" 
                    class="px-6 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                Search
            </button>
        </form>
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-2 mb-8 pb-4 border-b border-gray-200">
        @foreach (var category in Model.Categories)
        {
            <a href="@Url.Action("Index", new { search = Model.SearchTerm, category = category })"
               class="px-4 py-2 rounded-full text-sm font-medium transition-colors @(Model.SelectedCategory == category ? "bg-primary-600 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                @(category == "all" ? "All" : category)
            </a>
        }
    </div>

    <!-- Resources Grid -->
    @if (Model.Resources.Any())
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            @foreach (var resource in Model.Resources)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-all duration-200">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-start space-x-4">
                            <div class="w-12 h-12 @GetTypeBgColor(resource.Type) rounded-lg flex items-center justify-center flex-shrink-0">
                                <i class="@GetTypeIcon(resource.Type) @GetTypeTextColor(resource.Type) text-xl"></i>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-gray-900 mb-1">@resource.Title</h3>
                                <div class="flex items-center text-sm text-gray-500">
                                    <i class="fas fa-calendar mr-1"></i>
                                    <span>@resource.UploadDate.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        </div>
                        <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-gray-100 rounded-full">
                            @resource.Type
                        </span>
                    </div>

                    <p class="text-sm text-gray-600 mb-4">@resource.Description</p>

                    @if (resource.Tags.Any())
                    {
                        <div class="flex flex-wrap gap-2 mb-4">
                            @foreach (var tag in resource.Tags)
                            {
                                <span class="px-2 py-1 text-xs font-medium text-gray-700 bg-gray-100 rounded-full">
                                    @tag
                                </span>
                            }
                        </div>
                    }

                    <div class="flex items-center justify-between pt-4 border-t border-gray-200">
                        <div class="flex items-center space-x-4 text-sm text-gray-600">
                            <div class="flex items-center">
                                <i class="fas fa-download mr-1"></i>
                                <span>@resource.Downloads downloads</span>
                            </div>
                            <span class="px-2 py-1 text-xs font-medium text-gray-700 bg-gray-100 rounded-full">
                                @resource.Category
                            </span>
                        </div>
                    </div>

                    <div class="flex space-x-3 mt-4">
                        <a asp-action="Details" asp-route-id="@resource.Id" 
                           class="flex-1 px-4 py-2 border border-primary-600 text-primary-600 rounded-lg hover:bg-primary-50 transition-colors text-center font-medium">
                            <i class="fas fa-eye mr-2"></i>Preview
                        </a>
                        <form asp-action="Download" asp-route-id="@resource.Id" method="post" class="flex-1">
                            <button type="submit" 
                                    class="w-full px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                                <i class="fas fa-download mr-2"></i>Download
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-12">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-folder-open text-gray-400 text-2xl"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">No resources found</h3>
            <p class="text-gray-600 mb-4">Try adjusting your search terms or browse different categories.</p>
        </div>
    }
</div>

@functions {
    string GetTypeIcon(string type)
    {
        return type switch
        {
            "pdf" or "guide" => "fas fa-file-pdf",
            "video" => "fas fa-video",
            "template" => "fas fa-file-alt",
            "toolkit" => "fas fa-archive",
            _ => "fas fa-file"
        };
    }
    
    string GetTypeTextColor(string type)
    {
        return type switch
        {
            "pdf" or "guide" => "text-red-600",
            "video" => "text-blue-600",
            "template" => "text-green-600",
            "toolkit" => "text-purple-600",
            _ => "text-gray-600"
        };
    }

    string GetTypeBgColor(string type)
    {
        return type switch
        {
            "pdf" or "guide" => "bg-red-100",
            "video" => "bg-blue-100",
            "template" => "bg-green-100",
            "toolkit" => "bg-purple-100",
            _ => "bg-gray-100"
        };
    }
}
