@model List<UnganaConnect.Models.Blog.BlogPostViewModel>
@{
    ViewData["Title"] = "Consultancy";
    var role = Context.Session.GetString("Role");
}

<div class="max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 mb-2">Consultancy</h1>
                <p class="text-gray-600">Read the latest insights, stories, and updates from our community</p>
            </div>
            @if (role == "Admin" || role == "Instructor")
            {
                <a asp-action="Create" 
                   class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-plus mr-2"></i>Create New Post
                </a>
            }
        </div>
    </div>

    <!-- Search Section -->
    <div class="mb-6">
        <form method="get" action="@Url.Action("Index")" class="flex gap-4">
            <div class="flex-1 relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i class="fas fa-search text-gray-400"></i>
                </div>
                <input type="text" 
                       name="search" 
                       class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                       placeholder="Search posts..." 
                       value="@ViewBag.SearchTerm" />
            </div>
            <button type="submit" 
                    class="px-6 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                Search
            </button>
        </form>
    </div>

    <!-- Status Filter (Admin/Instructor only) -->
    @if (role == "Admin" || role == "Instructor")
    {
        <div class="mb-6">
            <form method="get" action="@Url.Action("Index")">
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                {
                    <input type="hidden" name="search" value="@ViewBag.SearchTerm" />
                }
                <select name="status" 
                        onchange="this.form.submit()" 
                        class="px-4 py-2 border border-gray-300 rounded-lg bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                    <option value="All" selected="@(ViewBag.StatusFilter == "All")">All Status</option>
                    <option value="Published" selected="@(ViewBag.StatusFilter == "Published")">Published</option>
                    <option value="Draft" selected="@(ViewBag.StatusFilter == "Draft")">Draft</option>
                    <option value="Archived" selected="@(ViewBag.StatusFilter == "Archived")">Archived</option>
                </select>
            </form>
        </div>
    }

    <!-- Blog Posts Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            @foreach (var post in Model)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-all duration-200">
                    @if (!string.IsNullOrEmpty(post.FeaturedImageUrl))
                    {
                        <img src="@post.FeaturedImageUrl" alt="@post.Title" class="w-full h-48 object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-48 bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center">
                            <i class="fas fa-blog text-primary-400 text-5xl"></i>
                        </div>
                    }

                    <div class="p-6">
                        <!-- Badges -->
                        <div class="flex items-center gap-2 mb-3">
                            @if (post.IsFeatured)
                            {
                                <span class="px-3 py-1 text-xs font-semibold text-yellow-700 bg-yellow-100 rounded-full">
                                    <i class="fas fa-star mr-1"></i>Featured
                                </span>
                            }
                            <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-gray-100 rounded-full">
                                @post.Category
                            </span>
                            @if (role == "Admin" || role == "Instructor")
                            {
                                var statusColor = post.Status == "Published" ? "bg-green-100 text-green-700"
                                : post.Status == "Draft" ? "bg-yellow-100 text-yellow-700"
                                : "bg-gray-100 text-gray-700";

                                <span class="px-3 py-1 text-xs font-semibold rounded-full @statusColor">
                                    @post.Status
                                </span>
                            }

                        </div>

                        <h3 class="text-xl font-semibold text-gray-900 mb-2 line-clamp-2">
                            <a href="@Url.Action("Details", new { id = post.Id })" class="hover:text-primary-600 transition-colors">
                                @post.Title
                            </a>
                        </h3>

                        <p class="text-sm text-gray-600 mb-4 line-clamp-3">@post.Excerpt</p>

                        @if (!string.IsNullOrEmpty(post.Tags))
                        {
                            <div class="flex flex-wrap gap-2 mb-4">
                                @foreach (var tag in post.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()))
                                {
                                    <span class="px-2 py-1 text-xs font-medium text-gray-700 bg-gray-100 rounded-full">
                                        #@tag
                                    </span>
                                }
                            </div>
                        }

                        <!-- Author and Actions -->
                        <div class="flex items-center justify-between pt-4 border-t border-gray-200">
                            <div class="flex items-center space-x-3">
                                @if (!string.IsNullOrEmpty(post.AuthorProfilePicture))
                                {
                                    <img src="@post.AuthorProfilePicture" alt="@post.AuthorName" 
                                         class="w-10 h-10 rounded-full object-cover" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-semibold text-sm">
                                        @post.AuthorName.Substring(0, 1)
                                    </div>
                                }
                                <div>
                                    <p class="text-sm font-medium text-gray-900">@post.AuthorName</p>
                                    <p class="text-xs text-gray-500">
                                        @post.PublishedAt?.ToString("MMM dd, yyyy") ?? post.CreatedAt.ToString("MMM dd, yyyy")
                                    </p>
                                </div>
                            </div>
                            <div class="flex items-center space-x-2">
                                <span class="text-xs text-gray-500">
                                    <i class="fas fa-eye mr-1"></i>@post.Views
                                </span>
                                @if (role == "Admin" || role == "Instructor")
                                {
                                    <a href="@Url.Action("Edit", new { id = post.Id })" 
                                       class="p-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors"
                                       title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = post.Id })" 
                                       class="p-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 transition-colors"
                                       title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-blog text-gray-400 text-2xl"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">No blog posts found</h3>
            <p class="text-gray-600 mb-4">Check back later for new posts.</p>
            @if (role == "Admin" || role == "Instructor")
            {
                <a asp-action="Create" 
                   class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                    <i class="fas fa-plus mr-2"></i>Create Post
                </a>
            }
        </div>
    }
</div>
