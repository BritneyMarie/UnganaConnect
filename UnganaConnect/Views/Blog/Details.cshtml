@model UnganaConnect.Models.Blog.BlogPostViewModel
@{
    ViewData["Title"] = Model.Title;
    var role = Context.Session.GetString("Role");
}

<div class="max-w-7xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-gray-600">
            <li><a asp-action="Index" class="hover:text-primary-600 transition-colors">Consultancy</a></li>
            <li><i class="fas fa-chevron-right text-gray-400"></i></li>
            <li><a href="@Url.Action("Index", new { category = Model.Category })" class="hover:text-primary-600 transition-colors">@Model.Category</a></li>
            <li><i class="fas fa-chevron-right text-gray-400"></i></li>
            <li class="text-gray-900">@Model.Title</li>
        </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Content -->
        <div class="lg:col-span-2">
            <!-- Blog Post Card -->
            <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
                @if (!string.IsNullOrEmpty(Model.FeaturedImageUrl))
                {
                    <img src="@Model.FeaturedImageUrl" alt="@Model.Title" class="w-full h-96 object-cover" />
                }
                else
                {
                    <div class="w-full h-96 bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center">
                        <i class="fas fa-blog text-primary-400 text-6xl"></i>
                    </div>
                }

                <div class="p-8">
                    <!-- Badges -->
                    <div class="flex items-center gap-2 mb-4">
                        @if (Model.IsFeatured)
                        {
                            <span class="px-3 py-1 text-xs font-semibold text-yellow-700 bg-yellow-100 rounded-full">
                                <i class="fas fa-star mr-1"></i>Featured
                            </span>
                        }
                        <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-gray-100 rounded-full">
                            @Model.Category
                        </span>
                        @if (role == "Admin" || role == "Instructor")
                        {
                            {
                                var statusColor = Model.Status == "Published" ? "bg-green-100 text-green-700" :
                                                 Model.Status == "Draft" ? "bg-yellow-100 text-yellow-700" :
                                                 "bg-gray-100 text-gray-700";
                            }
                            <span class="px-3 py-1 text-xs font-semibold rounded-full">
                                @Model.Status
                            </span>
                        }
                    </div>

                    <h1 class="text-3xl font-bold text-gray-900 mb-6">@Model.Title</h1>

                    <!-- Author and Meta -->
                    <div class="flex items-center justify-between mb-6 pb-6 border-b border-gray-200">
                        <div class="flex items-center space-x-4">
                            @if (!string.IsNullOrEmpty(Model.AuthorProfilePicture))
                            {
                                <img src="@Model.AuthorProfilePicture" alt="@Model.AuthorName" 
                                     class="w-12 h-12 rounded-full object-cover" />
                            }
                            else
                            {
                                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-semibold text-lg">
                                    @Model.AuthorName.Substring(0, 1)
                                </div>
                            }
                            <div>
                                <p class="font-semibold text-gray-900">@Model.AuthorName</p>
                                <p class="text-sm text-gray-500">
                                    @if (Model.PublishedAt.HasValue)
                                    {
                                        <span>Published @Model.PublishedAt.Value.ToString("MMMM dd, yyyy 'at' HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span>Created @Model.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")</span>
                                    }
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center text-sm text-gray-500">
                            <i class="fas fa-eye mr-2"></i>
                            <span>@Model.Views views</span>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="prose max-w-none mb-6">
                        <div class="text-gray-700 leading-relaxed whitespace-pre-wrap">@Html.Raw(Model.Content.Replace("\n", "<br/>"))</div>
                    </div>

                    <!-- Tags -->
                    @if (!string.IsNullOrEmpty(Model.Tags))
                    {
                        <div class="mb-6 pt-6 border-t border-gray-200">
                            <h3 class="text-sm font-semibold text-gray-900 mb-3">Tags:</h3>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()))
                                {
                                    <span class="px-3 py-1 text-sm font-medium text-gray-700 bg-gray-100 rounded-full">
                                        #@tag
                                    </span>
                                }
                            </div>
                        </div>
                    }

                    <!-- Admin Actions -->
                    @if (role == "Admin" || role == "Instructor")
                    {
                        <div class="pt-6 border-t border-gray-200 flex items-center space-x-3">
                            <a asp-action="Edit" asp-route-id="@Model.Id" 
                               class="px-4 py-2 border border-primary-300 text-primary-600 rounded-lg hover:bg-primary-50 transition-colors font-medium inline-flex items-center">
                                <i class="fas fa-edit mr-2"></i>Edit Post
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" 
                               class="px-4 py-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 transition-colors font-medium inline-flex items-center">
                                <i class="fas fa-trash mr-2"></i>Delete Post
                            </a>
                        </div>
                    }
                </div>
            </article>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Post Info Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Post Information</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-1">Category</p>
                        <p class="text-gray-900">@Model.Category</p>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-1">Published</p>
                        @if (Model.PublishedAt.HasValue)
                        {
                            <p class="text-gray-900">@Model.PublishedAt.Value.ToString("MMMM dd, yyyy")</p>
                        }
                        else
                        {
                            <p class="text-gray-500">Not published</p>
                        }
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-1">Views</p>
                        <p class="text-gray-900">@Model.Views</p>
                    </div>
                    @if (Model.IsFeatured)
                    {
                        <div>
                            <span class="px-3 py-1 text-xs font-semibold text-yellow-700 bg-yellow-100 rounded-full">
                                <i class="fas fa-star mr-1"></i>Featured Post
                            </span>
                        </div>
                    }
                </div>
            </div>

            <!-- Author Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Author</h3>
                <div class="text-center">
                    @if (!string.IsNullOrEmpty(Model.AuthorProfilePicture))
                    {
                        <img src="@Model.AuthorProfilePicture" alt="@Model.AuthorName" 
                             class="w-20 h-20 rounded-full object-cover mx-auto mb-3" />
                    }
                    else
                    {
                        <div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-semibold text-2xl mx-auto mb-3">
                            @Model.AuthorName.Substring(0, 1)
                        </div>
                    }
                    <h4 class="font-semibold text-gray-900">@Model.AuthorName</h4>
                </div>
            </div>
        </div>
    </div>
</div>
