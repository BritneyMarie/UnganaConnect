@model IEnumerable<UnganaConnect.Models.Course.Course>
@{
    ViewData["Title"] = "Training Courses";
    var role = Context.Session.GetString("Role");
}

<div class="max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Training Courses</h1>
        <p class="text-gray-600">Enhance your skills with our comprehensive training programs</p>
    </div>

    <!-- Search and Filter Section -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
        <!-- Search Bar -->
        <div class="flex-1 max-w-md">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i class="fas fa-search text-gray-400"></i>
                </div>
                <input type="text" 
                       id="searchInput"
                       class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                       placeholder="Search courses...">
            </div>
        </div>

        <!-- Filter and Create Button -->
        <div class="flex items-center space-x-3">
            <button class="p-2 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">
                <i class="fas fa-filter"></i>
            </button>
            @if (role == "Admin")
            {
                <a asp-action="Create" 
                   class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                    <i class="fas fa-plus mr-2"></i>Create Course
                </a>
            }
        </div>
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-2 mb-8 pb-4 border-b border-gray-200">
        <button class="category-tab active px-4 py-2 bg-primary-600 text-white rounded-full text-sm font-medium transition-colors">
            All
        </button>
        <button class="category-tab px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Fundraising
        </button>
        <button class="category-tab px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Finance
        </button>
        <button class="category-tab px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Marketing
        </button>
        <button class="category-tab px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Management
        </button>
        <button class="category-tab px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Community
        </button>
        <button class="category-tab px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors">
            Analytics
        </button>
    </div>

    <!-- Course Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var course in Model)
        {
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-all duration-200 course-card">
                <!-- Course Image -->
                <div class="relative h-48 bg-gradient-to-br from-primary-100 to-primary-200">
                    @if (!string.IsNullOrWhiteSpace(course.ThumbnailUrl))
                    {
                        <img src="@course.ThumbnailUrl" alt="@course.Title" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center">
                            <i class="fas fa-book text-primary-400 text-5xl"></i>
                        </div>
                    }
                    
                    <!-- Status Badges -->
                    <div class="absolute top-3 left-3">
                        @if (course.Level == "Beginner")
                        {
                            <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-white rounded-full shadow-sm">Beginner</span>
                        }
                        else if (course.Level == "Intermediate")
                        {
                            <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-white rounded-full shadow-sm">Intermediate</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-white rounded-full shadow-sm">Advanced</span>
                        }
                    </div>
                    <div class="absolute top-3 right-3">
                        @if (course.Status == "available")
                        {
                            <span class="px-3 py-1 text-xs font-semibold text-white bg-primary-600 rounded-full">Available</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 text-xs font-semibold text-white bg-gray-600 rounded-full">@course.Status</span>
                        }
                    </div>
                </div>

                <!-- Course Content -->
                <div class="p-6 flex flex-col flex-1">
                    <h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2">@course.Title</h3>
                    <p class="text-sm text-gray-600 mb-4 line-clamp-2">@course.Description</p>

                    <!-- Course Meta -->
                    <div class="flex items-center space-x-4 text-sm text-gray-500 mb-4">
                        <div class="flex items-center">
                            <i class="fas fa-star text-yellow-400 mr-1"></i>
                            <span>4.8</span>
                        </div>
                        <div class="flex items-center">
                            <i class="fas fa-clock mr-1"></i>
                            <span>@course.Duration</span>
                        </div>
                        <div class="flex items-center">
                            <i class="fas fa-users mr-1"></i>
                            <span>245</span>
                        </div>
                    </div>

                    <!-- Category Tag -->
                    <div class="mb-4">
                        <span class="px-3 py-1 text-xs font-medium text-gray-700 bg-gray-100 rounded-full">
                            @course.Category
                        </span>
                    </div>

                    <!-- Action Buttons -->
                    <div class="mt-auto pt-4 border-t border-gray-200">
                        <div class="flex items-center justify-between">
                            <a asp-action="Details" asp-route-id="@course.Id" 
                               class="flex-1 px-4 py-2 border border-primary-600 text-primary-600 rounded-lg hover:bg-primary-50 transition-colors text-center font-medium">
                                <i class="fas fa-eye mr-2"></i>View Details
                            </a>
                            @if (role == "Admin")
                            {
                                <div class="ml-2 flex space-x-1">
                                    <a asp-action="Edit" asp-route-id="@course.Id" 
                                       class="p-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors"
                                       title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Publish" method="post" class="inline">
                                        <input type="hidden" name="id" value="@course.Id" />
                                        <button type="submit" 
                                                class="p-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors"
                                                title="Publish">
                                            <i class="fas fa-upload"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-span-full text-center py-12">
                <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-book-open text-gray-400 text-2xl"></i>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">No courses found</h3>
                <p class="text-gray-600 mb-4">Start by creating your first course</p>
                @if (role == "Admin")
                {
                    <a asp-action="Create" 
                       class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                        <i class="fas fa-plus mr-2"></i>Create Course
                    </a>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Simple category filter functionality
        document.querySelectorAll('.category-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.category-tab').forEach(t => {
                    t.classList.remove('active', 'bg-primary-600', 'text-white');
                    t.classList.add('bg-gray-100', 'text-gray-700');
                });
                this.classList.add('active', 'bg-primary-600', 'text-white');
                this.classList.remove('bg-gray-100', 'text-gray-700');
            });
        });
    </script>
}


