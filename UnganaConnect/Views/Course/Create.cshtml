@model UnganaConnect.Models.Course.Course
@{
    ViewData["Title"] = "Create Course";
}

<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Create New Course</h1>
        <p class="text-gray-600">Add a new training course to the platform</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

            <!-- Title and Category -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-2">
                        Course Title <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Title" 
                           class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                           placeholder="Enter course title"
                           required />
                    <span asp-validation-for="Title" class="text-red-600 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Category" class="block text-sm font-medium text-gray-700 mb-2">
                        Category <span class="text-red-500">*</span>
                    </label>
                    <select asp-for="Category" 
                            class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                            required>
                        <option value="">Select Category</option>
                        <option value="Fundraising">Fundraising</option>
                        <option value="Finance">Finance</option>
                        <option value="Marketing">Marketing</option>
                        <option value="Management">Management</option>
                        <option value="Community">Community</option>
                        <option value="Analytics">Analytics</option>
                    </select>
                    <span asp-validation-for="Category" class="text-red-600 text-xs mt-1"></span>
                </div>
            </div>

            <!-- Description -->
            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-2">
                    Description <span class="text-red-500">*</span>
                </label>
                <textarea asp-for="Description" 
                          rows="5"
                          class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                          placeholder="Enter course description"
                          required></textarea>
                <span asp-validation-for="Description" class="text-red-600 text-xs mt-1"></span>
            </div>

            <!-- Duration, Level, and Thumbnail -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label asp-for="Duration" class="block text-sm font-medium text-gray-700 mb-2">
                        Duration
                    </label>
                    <input asp-for="Duration" 
                           class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                           placeholder="e.g., 6 hours" />
                </div>

                <div>
                    <label asp-for="Level" class="block text-sm font-medium text-gray-700 mb-2">
                        Level
                    </label>
                    <select asp-for="Level" 
                            class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                        <option value="">Select Level</option>
                        <option value="Beginner">Beginner</option>
                        <option value="Intermediate">Intermediate</option>
                        <option value="Advanced">Advanced</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Thumbnail Image
                    </label>
                    <input type="file" 
                           name="thumbnailFile" 
                           accept="image/*"
                           class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>
            </div>

            <!-- Status -->
            <div>
                <label asp-for="Status" class="block text-sm font-medium text-gray-700 mb-2">
                    Status
                </label>
                <select asp-for="Status" 
                        class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                    <option value="draft">Draft</option>
                    <option value="available">Available</option>
                    <option value="archived">Archived</option>
                </select>
            </div>

            <!-- Action Buttons -->
            <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
                <a asp-action="Index" 
                   class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium">
                    Cancel
                </a>
                <button type="submit" 
                        class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                    <i class="fas fa-save mr-2"></i>Create Course
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
