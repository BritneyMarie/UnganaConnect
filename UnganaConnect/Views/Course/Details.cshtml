@model UnganaConnect.Models.Course.Course
@{
    ViewData["Title"] = Model.Title;
    var role = Context.Session.GetString("Role");
    var userId = Context.Session.GetString("UserId");
}

<div class="max-w-7xl mx-auto">
    <!-- Course Header Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 mb-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Course Image -->
            <div class="relative">
                @if (!string.IsNullOrWhiteSpace(Model.ThumbnailUrl))
                {
                    <img src="@Model.ThumbnailUrl" alt="@Model.Title" class="w-full h-64 object-cover rounded-xl" />
                }
                else
                {
                    <div class="w-full h-64 bg-gradient-to-br from-primary-100 to-primary-200 rounded-xl flex items-center justify-center">
                        <i class="fas fa-book text-primary-400 text-6xl"></i>
                    </div>
                }
                @if (Model.Level == "Beginner")
                {
                    <div class="absolute top-4 left-4">
                        <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-white rounded-full shadow-sm">Beginner</span>
                    </div>
                }
            </div>

            <!-- Course Info -->
            <div class="flex flex-col justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900 mb-3">@Model.Title</h1>
                    <p class="text-gray-600 mb-6">@Model.Description</p>

                    <div class="flex flex-wrap gap-3 mb-6">
                        <div class="flex items-center text-sm text-gray-600">
                            <i class="fas fa-tag mr-2"></i>
                            <span>@Model.Category</span>
                        </div>
                        <div class="flex items-center text-sm text-gray-600">
                            <i class="fas fa-layer-group mr-2"></i>
                            <span>@Model.Level</span>
                        </div>
                        <div class="flex items-center text-sm text-gray-600">
                            <i class="fas fa-clock mr-2"></i>
                            <span>@Model.Duration</span>
                        </div>
                    </div>

                    @if (role != "Admin")
                    {
                        @if ((bool?)ViewBag.IsEnrolled == true)
                        {
                            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">
                                <div class="flex items-center">
                                    <i class="fas fa-check-circle mr-2"></i>
                                    <span class="font-medium">You're enrolled in this course!</span>
                                </div>
                            </div>
                            @if (Model.Modules != null && Model.Modules.Any())
                            {
                                var firstModule = Model.Modules.OrderBy(x => x.Order).First();
                                <a asp-action="Learn" asp-route-id="@firstModule.Id" 
                                   class="inline-flex items-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                                    <i class="fas fa-play mr-2"></i>Continue Learning
                                </a>
                            }
                        }
                        else
                        {
                            <form method="post" asp-action="Enroll" class="mb-4">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="courseId" value="@Model.Id" />
                                <button type="submit" 
                                        class="inline-flex items-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                                    <i class="fas fa-plus-circle mr-2"></i>Enroll Now
                                </button>
                            </form>
                        }
                    }
                </div>

                <!-- Course Stats -->
                <div class="grid grid-cols-3 gap-4 pt-6 border-t border-gray-200">
                    <div class="text-center">
                        <div class="text-2xl font-bold text-gray-900">4.8</div>
                        <div class="text-sm text-gray-600">Rating</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-gray-900">245</div>
                        <div class="text-sm text-gray-600">Students</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-gray-900">@Model.Modules.Count</div>
                        <div class="text-sm text-gray-600">Modules</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Course Modules -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-1">Course Modules</h2>
                <p class="text-gray-600">Complete all modules to finish the course</p>
            </div>
            @if (role == "Admin" || role == "Instructor")
            {
                <a asp-action="CreateModule" asp-route-courseId="@Model.Id" 
                   class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-plus mr-2"></i>Add Module
                </a>
            }
        </div>

        @if (Model.Modules != null && Model.Modules.Any())
        {
            <div class="space-y-4">
                @foreach (var module in Model.Modules.OrderBy(x => x.Order))
                {
                    <div class="border border-gray-200 rounded-lg p-6 hover:border-primary-300 transition-colors">
                        <div class="flex items-center justify-between">
                            <div class="flex items-start space-x-4 flex-1">
                                <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <span class="text-primary-600 font-bold">@module.Order</span>
                                </div>
                                <div class="flex-1">
                                    <h3 class="text-lg font-semibold text-gray-900 mb-2">@module.Title</h3>
                                    @if (module.Quizzes != null && module.Quizzes.Any())
                                    {
                                        <div class="flex flex-wrap gap-2 mb-3">
                                            @foreach (var quiz in module.Quizzes)
                                            {
                                                <a asp-action="TakeQuiz" asp-route-quizId="@quiz.Id" 
                                                   class="inline-flex items-center px-3 py-1 text-sm border border-primary-300 text-primary-700 bg-primary-50 rounded-lg hover:bg-primary-100 transition-colors">
                                                    <i class="fas fa-clipboard-check mr-1"></i>@quiz.Title
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                @if (role == "Admin" || role == "Instructor")
                                {
                                    <div class="flex items-center gap-2">
                                        <a asp-action="CreateQuiz" asp-route-moduleId="@module.Id" 
                                           class="px-4 py-2 text-sm bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium inline-flex items-center">
                                            <i class="fas fa-plus mr-2"></i>Add Quiz
                                        </a>
                                        <a asp-action="EditModule" asp-route-id="@module.Id" 
                                           class="px-4 py-2 text-sm bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                                            <i class="fas fa-edit mr-2"></i>Edit Module
                                        </a>
                                    </div>
                                }
                                @if (role != "Admin")
                                {
                                    <a asp-action="Learn" asp-route-id="@module.Id" 
                                       class="px-4 py-2 border border-primary-600 text-primary-600 rounded-lg hover:bg-primary-50 transition-colors font-medium inline-flex items-center">
                                        <i class="fas fa-play mr-2"></i>Start
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-book-open text-gray-400 text-2xl"></i>
                </div>
                <p class="text-gray-600 mb-4">No modules available for this course yet.</p>
                @if (role == "Admin" || role == "Instructor")
                {
                    <a asp-action="CreateModule" asp-route-courseId="@Model.Id" 
                       class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
                        <i class="fas fa-plus mr-2"></i>Add First Module
                    </a>
                }
            </div>
        }
    </div>
</div>
