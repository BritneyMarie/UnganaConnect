@model UnganaConnect.Models.Course.Quiz
@{
    ViewData["Title"] = "Create Quiz";
}

<div class="container py-4">
    <h2 class="mb-3">Create Quiz - @ViewBag.ModuleTitle</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="CreateQuiz" method="post" class="row g-3">
                <input type="hidden" asp-for="ModuleId" />
                <div class="col-md-6">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label class="form-label">Instructions</label>
                    <textarea asp-for="Instructions" class="form-control" rows="3"></textarea>
                </div>

                <hr />
                <div id="questions">
                    <!-- dynamic questions inserted by JS -->
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" id="add-question"><i class="fas fa-plus me-1"></i>Add Question</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Create Quiz</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        const questions = document.getElementById('questions');
        const addBtn = document.getElementById('add-question');
        let qIndex = 0;

        function addQuestion() {
            const qWrap = document.createElement('div');
            qWrap.className = 'border rounded p-3 mb-3';
            qWrap.innerHTML = `
                <div class="mb-2">
                    <label class="form-label">Question</label>
                    <input name="questionTexts[${qIndex}]" class="form-control" />
                </div>
                <div data-options>
                </div>
                <div class="d-flex gap-2 mt-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-add-option>Add Option</button>
                </div>
            `;
            const optionsHost = qWrap.querySelector('[data-options]');
            let oIndex = 0;
            function addOption() {
                const opt = document.createElement('div');
                opt.className = 'input-group mb-2';
                opt.innerHTML = `
                    <div class="input-group-text">
                        <input class="form-check-input mt-0" type="radio" name="correctOptionIndexes[${qIndex}]" value="${oIndex}" />
                    </div>
                    <input class="form-control" name="options[${qIndex}][${oIndex}]" placeholder="Option text" />
                `;
                optionsHost.appendChild(opt);
                oIndex++;
            }
            qWrap.querySelector('[data-add-option]').addEventListener('click', addOption);
            addOption();
            addOption();
            questions.appendChild(qWrap);
            qIndex++;
        }
        addBtn.addEventListener('click', addQuestion);
        addQuestion();
    })();
</script>


