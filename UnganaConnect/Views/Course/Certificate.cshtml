@model UnganaConnect.Frontend.Models.CertificateViewModel
@{
    ViewData["Title"] = "Certificate";
}

<div class="container py-5">
    <div class="card shadow-lg mx-auto" style="max-width: 900px; border: 6px double #ccc;">
        <div class="card-body p-5 text-center">
            <h1 class="display-6 mb-0">Certificate of Completion</h1>
            <p class="text-muted">Certificate ID: @Model.CertificateId</p>
            <hr />
            <p class="lead">This is to certify that</p>
            <h2 class="mb-3">@Model.UserName</h2>
            <p class="lead">has successfully completed the course</p>
            <h3 class="mb-3">@Model.CourseTitle</h3>
            <p class="text-muted">Instructor: @Model.Instructor</p>
            <p class="mb-4">Date: @Model.CompletionDate</p>
            <div class="d-flex justify-content-center gap-3">
                <a class="btn btn-outline-primary" onclick="window.print()"><i class="fas fa-print me-1"></i>Print</a>
                <a class="btn btn-primary" href="@Url.Action("Details", "Course", new { id = 0 })">Back to Courses</a>
            </div>
        </div>
    </div>
</div>


