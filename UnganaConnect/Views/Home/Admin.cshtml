@model UnganaConnect.Frontend.Models.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="max-w-7xl mx-auto">
    <!-- Welcome Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Welcome back!</h1>
        <p class="text-gray-600">Track your platform analytics and manage all resources</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Courses Completed Card -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-600 mb-1">Total Courses</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Stats.TotalCourses</p>
                    <p class="text-xs text-green-600 mt-1">
                        <i class="fas fa-book mr-1"></i>Available courses
                    </p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-book text-blue-600 text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Certificates Earned Card -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-600 mb-1">Active Users</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Stats.ActiveUsers</p>
                    <p class="text-xs text-green-600 mt-1">
                        <i class="fas fa-users mr-1"></i>Registered users
                    </p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-users text-green-600 text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Resources Downloaded Card -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-600 mb-1">Resources</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Stats.TotalResources</p>
                    <p class="text-xs text-purple-600 mt-1">
                        <i class="fas fa-folder-open mr-1"></i>Total resources
                    </p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-folder-open text-purple-600 text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Events Attended Card -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-600 mb-1">Upcoming Events</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Stats.UpcomingEventsCount</p>
                    <p class="text-xs text-orange-600 mt-1">
                        <i class="fas fa-calendar mr-1"></i>Scheduled events
                    </p>
                </div>
                <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-calendar-alt text-orange-600 text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Manage Courses Card -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-1">Manage Courses</h3>
                    <p class="text-sm text-gray-600">Create, edit, publish and manage modules and quizzes</p>
                </div>
                <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-book text-primary-600 text-xl"></i>
                </div>
            </div>
            <div class="flex space-x-3">
                <a href="@Url.Action("Index", "Course")" 
                   class="flex-1 px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors text-center font-medium">
                    <i class="fas fa-book mr-2"></i>View Courses
                </a>
                <a href="@Url.Action("Create", "Course")" 
                   class="flex-1 px-4 py-2 border border-primary-600 text-primary-600 rounded-lg hover:bg-primary-50 transition-colors text-center font-medium">
                    <i class="fas fa-plus mr-2"></i>Create New
                </a>
            </div>
        </div>

        <!-- Manage Resources Card -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-1">Resources</h3>
                    <p class="text-sm text-gray-600">Upload and manage learning resources</p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-folder-open text-purple-600 text-xl"></i>
                </div>
            </div>
            <a href="@Url.Action("Index", "Resource")" 
               class="w-full px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors text-center font-medium block">
                <i class="fas fa-folder-open mr-2"></i>Manage Resources
            </a>
        </div>
    </div>

    <!-- Upcoming Events Section -->
    @if (Model.UpcomingEvents != null && Model.UpcomingEvents.Any())
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-1">Upcoming Events</h3>
                    <p class="text-sm text-gray-600">Don't miss these opportunities</p>
                </div>
                <a href="@Url.Action("Index", "Event")" 
                   class="text-primary-600 hover:text-primary-700 font-medium text-sm">
                    View All <i class="fas fa-arrow-right ml-1"></i>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                @foreach (var evt in Model.UpcomingEvents)
                {
                    <div class="border border-gray-200 rounded-lg p-4 hover:border-primary-300 transition-colors">
                        <div class="flex items-start space-x-3">
                            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-calendar text-primary-600"></i>
                            </div>
                            <div class="flex-1">
                                <h4 class="font-semibold text-gray-900 mb-1">@evt.Title</h4>
                                <div class="flex items-center text-sm text-gray-600 mb-2">
                                    <i class="fas fa-calendar-alt mr-2"></i>
                                    <span>@evt.Date.ToString("MMMM dd, yyyy")</span>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-2 py-1 text-xs font-medium text-gray-700 bg-gray-100 rounded-full">@evt.Type</span>
                                    <span class="px-2 py-1 text-xs font-medium text-gray-700 bg-gray-100 rounded-full">@evt.Format</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Additional Management Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Community Card -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900">Community</h3>
                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-comments text-blue-600"></i>
                </div>
            </div>
            <p class="text-sm text-gray-600 mb-4">Moderate forums and discussions</p>
            <a href="@Url.Action("Index", "Forum")" 
               class="inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium">
                <i class="fas fa-comments mr-2"></i>Manage Forums
            </a>
        </div>

        <!-- Events Card -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900">Events</h3>
                <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-calendar-alt text-orange-600"></i>
                </div>
            </div>
            <p class="text-sm text-gray-600 mb-4">Create and manage platform events</p>
            <a href="@Url.Action("Index", "Event")" 
               class="inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium">
                <i class="fas fa-calendar-alt mr-2"></i>Manage Events
            </a>
        </div>

        <!-- Blog Card -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900">Consultancy</h3>
                <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-blog text-green-600"></i>
                </div>
            </div>
            <p class="text-sm text-gray-600 mb-4">Create and publish blog posts</p>
            <a href="@Url.Action("Index", "Blog")" 
               class="inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium">
                <i class="fas fa-blog mr-2"></i>Manage Blog
            </a>
        </div>
    </div>
</div>
