@using UnganaConnect.Frontend.Models
@model ForumTopicDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="max-w-7xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-gray-600">
            <li><a asp-action="Index" class="hover:text-primary-600 transition-colors">Community</a></li>
            <li><i class="fas fa-chevron-right text-gray-400"></i></li>
            <li><a href="#" class="hover:text-primary-600 transition-colors">@Model.CategoryName</a></li>
            <li><i class="fas fa-chevron-right text-gray-400"></i></li>
            <li class="text-gray-900">@Model.Title</li>
        </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Topic Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <div class="flex items-center gap-2 mb-4">
                    @if (Model.IsPinned)
                    {
                        <i class="fas fa-thumbtack text-yellow-500"></i>
                    }
                    <span class="px-3 py-1 text-xs font-semibold text-blue-700 bg-blue-100 rounded-full">
                        @Model.CategoryName
                    </span>
                    @if (Model.IsAnswered)
                    {
                        <span class="px-3 py-1 text-xs font-semibold text-green-700 bg-green-100 rounded-full">
                            Answered
                        </span>
                    }
                </div>

                <h1 class="text-3xl font-bold text-gray-900 mb-4">@Model.Title</h1>

                @if (Model.Tags != null && Model.Tags.Any())
                {
                    <div class="flex flex-wrap gap-2 mb-6">
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="px-3 py-1 text-sm font-medium text-gray-700 bg-gray-100 rounded-full">
                                #@tag
                            </span>
                        }
                    </div>
                }

                <div class="prose max-w-none mb-6">
                    <div class="text-gray-700 leading-relaxed whitespace-pre-wrap">@Html.Raw(Model.Excerpt.Replace("\n", "<br/>"))</div>
                </div>

                <!-- Author Info -->
                <div class="flex items-center justify-between pt-6 border-t border-gray-200">
                    <div class="flex items-center space-x-3">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-semibold text-sm">
                            @string.Join("", Model.Author.Split(' ').Select(n => n.FirstOrDefault()))
                        </div>
                        <div>
                            <p class="font-semibold text-gray-900">@Model.Author</p>
                            <p class="text-sm text-gray-500">@Model.AuthorRole • @Model.AuthorOrg</p>
                            <p class="text-xs text-gray-500">Posted @Model.CreatedAt.ToString("MMM dd, yyyy 'at' HH:mm")</p>
                        </div>
                    </div>

                    <div class="flex items-center gap-2">
                        <button class="px-3 py-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium inline-flex items-center">
                            <i class="fas fa-thumbs-up mr-2"></i>Like
                        </button>
                        <button class="px-3 py-2 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium inline-flex items-center">
                            <i class="fas fa-thumbs-down mr-2"></i>Dislike
                        </button>
                        <button class="px-3 py-2 border border-primary-300 text-primary-600 rounded-lg hover:bg-primary-50 transition-colors text-sm font-medium inline-flex items-center">
                            <i class="fas fa-reply mr-2"></i>Reply
                        </button>
                    </div>
                </div>
            </div>

            <!-- Replies Section -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-xl font-semibold text-gray-900">
                        <i class="fas fa-comments mr-2 text-primary-600"></i>@Model.Replies Replies
                    </h2>
                </div>

                <!-- Reply Form -->
                @if (!string.IsNullOrEmpty(Context.Session.GetString("UserEmail")))
                {
                    <div class="mb-6 pb-6 border-b border-gray-200">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4">Add your reply</h3>
                        <form asp-action="Reply" method="post" class="space-y-4">
                            <input type="hidden" name="topicId" value="@Model.Id" />
                            <div>
                                <textarea name="content" 
                                          rows="5"
                                          class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                                          placeholder="Share your thoughts or answer..."
                                          required></textarea>
                            </div>
                            <button type="submit" 
                                    class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                                <i class="fas fa-paper-plane mr-2"></i>Post Reply
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="mb-6 pb-6 border-b border-gray-200 bg-blue-50 border border-blue-200 rounded-lg p-4">
                        <p class="text-sm text-blue-700">
                            <a asp-controller="Auth" asp-action="Login" class="font-medium text-blue-900 hover:text-blue-800 underline">Log in</a> to reply to this topic.
                        </p>
                    </div>
                }

                <!-- Replies List -->
                @if (Model.RepliesList != null && Model.RepliesList.Any())
                {
                    <div class="space-y-6">
                        @foreach (var reply in Model.RepliesList)
                        {
                            <div class="border border-gray-200 rounded-lg p-4 hover:border-primary-300 transition-colors">
                                <div class="flex items-start space-x-3">
                                    <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-700 font-semibold text-sm flex-shrink-0">
                                        @string.Join("", reply.Author.Split('@')[0].Split('.').Select(n => n.FirstOrDefault().ToString().ToUpper()))
                                    </div>
                                    <div class="flex-1">
                                        <div class="flex items-center justify-between mb-2">
                                            <div>
                                                <p class="font-semibold text-gray-900">@reply.Author</p>
                                                <p class="text-xs text-gray-500">@reply.CreatedAt.ToString("MMM dd, yyyy 'at' HH:mm")</p>
                                            </div>
                                        </div>
                                        <p class="text-gray-700 mb-3 leading-relaxed">@reply.Content</p>
                                        <div class="flex items-center gap-2">
                                            <button class="px-3 py-1 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors text-xs font-medium inline-flex items-center">
                                                <i class="fas fa-thumbs-up mr-1"></i>Like
                                            </button>
                                            <button class="px-3 py-1 border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition-colors text-xs font-medium inline-flex items-center">
                                                <i class="fas fa-thumbs-down mr-1"></i>Dislike
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12">
                        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="fas fa-comments text-gray-400 text-2xl"></i>
                        </div>
                        <p class="text-gray-600">No replies yet. Be the first to reply!</p>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Topic Stats Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Topic Stats</h3>
                <div class="grid grid-cols-3 gap-4 text-center">
                    <div>
                        <div class="text-2xl font-bold text-primary-600 mb-1">@Model.Views</div>
                        <div class="text-xs text-gray-600">Views</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold text-green-600 mb-1">@Model.Replies</div>
                        <div class="text-xs text-gray-600">Replies</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold text-blue-600 mb-1">@Model.Tags.Count</div>
                        <div class="text-xs text-gray-600">Tags</div>
                    </div>
                </div>
            </div>

            <!-- Related Topics Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Related Topics</h3>
                <div class="space-y-3">
                    <a href="#" class="block p-3 border border-gray-200 rounded-lg hover:border-primary-300 hover:bg-primary-50 transition-colors">
                        <p class="font-semibold text-gray-900 text-sm mb-1">Effective donor communication strategies</p>
                        <p class="text-xs text-gray-500">12 replies • 2 days ago</p>
                    </a>
                    <a href="#" class="block p-3 border border-gray-200 rounded-lg hover:border-primary-300 hover:bg-primary-50 transition-colors">
                        <p class="font-semibold text-gray-900 text-sm mb-1">Building long-term partnerships</p>
                        <p class="text-xs text-gray-500">8 replies • 3 days ago</p>
                    </a>
                    <a href="#" class="block p-3 border border-gray-200 rounded-lg hover:border-primary-300 hover:bg-primary-50 transition-colors">
                        <p class="font-semibold text-gray-900 text-sm mb-1">Grant reporting best practices</p>
                        <p class="text-xs text-gray-500">15 replies • 1 week ago</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
