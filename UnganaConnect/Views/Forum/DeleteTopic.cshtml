@model UnganaConnect.Frontend.Models.ForumTopicViewModel
@{
    ViewData["Title"] = "Delete Topic";
}

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Delete Topic</h1>
        <p class="text-gray-600">Are you sure you want to delete this topic?</p>
    </div>

    <!-- Warning Card -->
    <div class="bg-red-50 border border-red-200 rounded-xl p-6 mb-6">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <i class="fas fa-exclamation-triangle text-red-600 text-2xl"></i>
            </div>
            <div class="ml-3">
                <h3 class="text-lg font-semibold text-red-900 mb-2">Warning: This action cannot be undone</h3>
                <p class="text-red-700">This will permanently delete the topic "@Model.Title" and all associated replies.</p>
            </div>
        </div>
    </div>

    <!-- Topic Info Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Topic Details</h3>
        <div class="space-y-3">
            <div class="flex items-start">
                <span class="text-sm font-medium text-gray-700 w-32">Title:</span>
                <span class="text-gray-900">@Model.Title</span>
            </div>
            <div class="flex items-start">
                <span class="text-sm font-medium text-gray-700 w-32">Category:</span>
                <span class="text-gray-900">@Model.CategoryName</span>
            </div>
            <div class="flex items-start">
                <span class="text-sm font-medium text-gray-700 w-32">Author:</span>
                <span class="text-gray-900">@Model.Author</span>
            </div>
            <div class="flex items-start">
                <span class="text-sm font-medium text-gray-700 w-32">Created:</span>
                <span class="text-gray-900">@Model.CreatedAt.ToString("MMMM dd, yyyy")</span>
            </div>
            <div class="flex items-start">
                <span class="text-sm font-medium text-gray-700 w-32">Replies:</span>
                <span class="text-gray-900">@Model.Replies</span>
            </div>
        </div>
    </div>

    <!-- Delete Form -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <form asp-action="DeleteTopic" method="post" class="space-y-6">
            <input type="hidden" name="id" value="@Model.Id" />
            
            <div class="flex items-center justify-end space-x-4">
                <a asp-action="Index" 
                   class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-times mr-2"></i>Cancel
                </a>
                <button type="submit" 
                        class="px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-trash mr-2"></i>Delete Topic
                </button>
            </div>
        </form>
    </div>
</div>
