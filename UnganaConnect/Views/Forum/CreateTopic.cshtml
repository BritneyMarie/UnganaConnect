@model UnganaConnect.Frontend.Models.CreateTopicViewModel
@{
    ViewData["Title"] = "Create New Topic";
}

<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Create New Topic</h1>
        <p class="text-gray-600">Start a new discussion in the community</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        @if (TempData["Success"] != null)
        {
            <div class="mb-6 bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg">
                @TempData["Success"]
            </div>
        }

        <form asp-action="CreateTopic" method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

            <!-- Title -->
            <div>
                <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-2">
                    Topic Title <span class="text-red-500">*</span>
                </label>
                <input asp-for="Title" 
                       class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                       placeholder="Enter your topic title..."
                       required />
                <span asp-validation-for="Title" class="text-red-600 text-xs mt-1"></span>
            </div>

            <!-- Category -->
            <div>
                <label asp-for="CategoryId" class="block text-sm font-medium text-gray-700 mb-2">
                    Category <span class="text-red-500">*</span>
                </label>
                <select asp-for="CategoryId" 
                        class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                        required>
                    <option value="">Select a category...</option>
                    @foreach (var category in ViewBag.Categories as List<UnganaConnect.Frontend.Models.ForumCategory>)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-red-600 text-xs mt-1"></span>
            </div>

            <!-- Content -->
            <div>
                <label asp-for="Content" class="block text-sm font-medium text-gray-700 mb-2">
                    Content <span class="text-red-500">*</span>
                </label>
                <textarea asp-for="Content" 
                          rows="10"
                          class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                          placeholder="Share your thoughts, questions, or experiences..."
                          required></textarea>
                <span asp-validation-for="Content" class="text-red-600 text-xs mt-1"></span>
            </div>

            <!-- Tags -->
            <div>
                <label asp-for="Tags" class="block text-sm font-medium text-gray-700 mb-2">
                    Tags
                </label>
                <input asp-for="Tags" 
                       class="block w-full px-4 py-3 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                       placeholder="Add tags separated by commas..." />
                <p class="text-xs text-gray-500 mt-1">Use tags to help others find your topic</p>
                <span asp-validation-for="Tags" class="text-red-600 text-xs mt-1"></span>
            </div>

            <!-- Action Buttons -->
            <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
                <a asp-action="Index" 
                   class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-times mr-2"></i>Cancel
                </a>
                <button type="submit" 
                        class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-paper-plane mr-2"></i>Post Topic
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
