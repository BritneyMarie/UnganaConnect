@model UnganaConnect.Frontend.Models.ForumViewModel
@{
    ViewData["Title"] = "Community";
    var userEmail = Context.Session.GetString("UserEmail");
}

<div class="max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 mb-2">Community</h1>
                <p class="text-gray-600">Connect, collaborate, and share knowledge with CSOs across Africa</p>
            </div>
            @if (!string.IsNullOrEmpty(userEmail))
            {
                <a href="@Url.Action("CreateTopic")" 
                   class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-plus mr-2"></i>New Topic
                </a>
            }
        </div>
    </div>

    <!-- Tabs -->
    <div class="flex space-x-1 mb-6 border-b border-gray-200">
        <button class="forum-tab active px-4 py-2 text-sm font-medium text-primary-600 border-b-2 border-primary-600">
            Categories
        </button>
        <button class="forum-tab px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 border-b-2 border-transparent hover:border-gray-300">
            Recent Discussions
        </button>
        <button class="forum-tab px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 border-b-2 border-transparent hover:border-gray-300">
            Trending
        </button>
    </div>

    <!-- Categories Tab Content -->
    <div id="categories-tab" class="tab-content">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @foreach (var category in Model.Categories)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-all duration-200">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex-1">
                            <h3 class="text-lg font-semibold text-gray-900 mb-2">@category.Name</h3>
                            <p class="text-sm text-gray-600 mb-4">@category.Description</p>
                        </div>
                    </div>
                    <div class="flex items-center justify-between pt-4 border-t border-gray-200">
                        <div class="flex items-center space-x-4 text-sm text-gray-500">
                            <span><i class="fas fa-comments mr-1"></i>@category.PostsCount posts</span>
                            <span><i class="fas fa-users mr-1"></i>Active community</span>
                        </div>
                        <a href="@Url.Action("Topic", new { categoryId = category.Id })" 
                           class="text-primary-600 hover:text-primary-700 font-medium text-sm">
                            View <i class="fas fa-arrow-right ml-1"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Recent Discussions Tab Content -->
    <div id="recent-tab" class="tab-content hidden">
        <div class="mb-6">
            <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1 relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-search text-gray-400"></i>
                    </div>
                    <input type="text" 
                           class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" 
                           placeholder="Search discussions...">
                </div>
                <button class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium">
                    <i class="fas fa-filter mr-2"></i>Filter
                </button>
            </div>
        </div>

        <div class="space-y-4">
            @foreach (var topic in Model.RecentTopics)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-all duration-200">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 mb-3">
                                @if (topic.IsPinned)
                                {
                                    <i class="fas fa-thumbtack text-yellow-500"></i>
                                }
                                <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-gray-100 rounded-full">
                                    @topic.CategoryName
                                </span>
                                @if (topic.IsAnswered)
                                {
                                    <span class="px-3 py-1 text-xs font-semibold text-green-700 bg-green-100 rounded-full">
                                        Answered
                                    </span>
                                }
                            </div>
                            
                            <h3 class="text-lg font-semibold text-gray-900 mb-2">
                                <a href="@Url.Action("Topic", new { id = topic.Id })" class="hover:text-primary-600 transition-colors">
                                    @topic.Title
                                </a>
                            </h3>
                            
                            <p class="text-sm text-gray-600 mb-4 line-clamp-2">@topic.Excerpt</p>
                            
                            @if (topic.Tags != null && topic.Tags.Any())
                            {
                                <div class="flex flex-wrap gap-2 mb-4">
                                    @foreach (var tag in topic.Tags)
                                    {
                                        <span class="px-2 py-1 text-xs font-medium text-gray-700 bg-gray-100 rounded-full">
                                            #@tag
                                        </span>
                                    }
                                </div>
                            }
                            
                            <div class="flex items-center space-x-4 text-sm text-gray-500">
                                <span><i class="fas fa-comments mr-1"></i>@topic.Replies replies</span>
                                <span><i class="fas fa-eye mr-1"></i>@topic.Views views</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-4 pt-4 border-t border-gray-200 flex items-center justify-between">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-semibold text-sm">
                                @string.Join("", topic.Author.Split(' ').Select(n => n.FirstOrDefault()))
                            </div>
                            <div>
                                <p class="text-sm font-medium text-gray-900">@topic.Author</p>
                                <p class="text-xs text-gray-500">@topic.AuthorRole • @topic.CreatedAt.ToString("MMM dd, yyyy")</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Trending Tab Content -->
    <div id="trending-tab" class="tab-content hidden">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2">
                <h3 class="text-xl font-semibold text-gray-900 mb-4">Trending Topics</h3>
                <p class="text-gray-600 mb-6">Most discussed topics this week</p>
                
                <div class="space-y-4">
                    @for (int i = 0; i < Model.TrendingTopics.Count; i++)
                    {
                        var topic = Model.TrendingTopics[i];
                        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-all duration-200">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-4">
                                    <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-bold">
                                        @(i + 1)
                                    </div>
                                    <div>
                                        <h4 class="text-lg font-semibold text-gray-900">#@topic.Tag</h4>
                                        <p class="text-sm text-gray-500">@topic.Posts posts this week</p>
                                    </div>
                                </div>
                                <i class="fas fa-trending-up text-green-500 text-xl"></i>
                            </div>
                        </div>
                    }
                </div>
            </div>
            
            <div class="lg:col-span-1 space-y-6">
                <!-- Top Contributors -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <h4 class="text-lg font-semibold text-gray-900 mb-4">Top Contributors</h4>
                    <div class="space-y-3">
                        @foreach (var contributor in Model.TopContributors)
                        {
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-700 font-semibold text-sm">
                                        @string.Join("", contributor.Name.Split(' ').Select(n => n.FirstOrDefault()))
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">@contributor.Name</p>
                                        <p class="text-xs text-gray-500">@contributor.Posts posts</p>
                                    </div>
                                </div>
                                <span class="px-2 py-1 text-xs font-semibold text-gray-700 bg-gray-100 rounded-full">
                                    @contributor.Reputation
                                </span>
                            </div>
                        }
                    </div>
                </div>
                
                <!-- Forum Guidelines -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <h4 class="text-lg font-semibold text-gray-900 mb-4">Forum Guidelines</h4>
                    <ul class="space-y-2 text-sm text-gray-600">
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mr-2 mt-0.5"></i>
                            <span>Be respectful and professional</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mr-2 mt-0.5"></i>
                            <span>Share knowledge and experiences</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mr-2 mt-0.5"></i>
                            <span>Use appropriate categories</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-primary-600 mr-2 mt-0.5"></i>
                            <span>Search before posting</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.forum-tab').forEach((tab, index) => {
            tab.addEventListener('click', function() {
                // Update tab styles
                document.querySelectorAll('.forum-tab').forEach(t => {
                    t.classList.remove('active', 'text-primary-600', 'border-primary-600');
                    t.classList.add('text-gray-600', 'border-transparent');
                });
                this.classList.add('active', 'text-primary-600', 'border-primary-600');
                this.classList.remove('text-gray-600', 'border-transparent');
                
                // Show/hide tab content
                const tabs = ['categories', 'recent', 'trending'];
                tabs.forEach((tabName, i) => {
                    const content = document.getElementById(tabName + '-tab');
                    if (content) {
                        content.classList.toggle('hidden', i !== index);
                    }
                });
            });
        });
    </script>
}
