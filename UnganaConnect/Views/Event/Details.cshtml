@model UnganaConnect.Frontend.Models.Event
@{
    ViewData["Title"] = Model.Title;
    var userEmail = Context.Session.GetString("UserEmail");
    var userRole = Context.Session.GetString("Role");
}

<div class="max-w-7xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-gray-600">
            <li><a asp-action="Index" class="hover:text-primary-600 transition-colors">Events</a></li>
            <li><i class="fas fa-chevron-right text-gray-400"></i></li>
            <li class="text-gray-900">@Model.Title</li>
        </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Event Header Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <div class="flex items-start justify-between mb-6">
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-4">
                            <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-gray-100 rounded-full">
                                @Model.Type
                            </span>
                            <span class="px-3 py-1 text-xs font-semibold text-primary-700 bg-primary-50 rounded-full">
                                @if (Model.Format == "Virtual")
                                {
                                    <i class="fas fa-video mr-1"></i>
                                }
                                else if (Model.Format == "Hybrid")
                                {
                                    <i class="fas fa-globe mr-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-map-marker-alt mr-1"></i>
                                }
                                @Model.Format
                            </span>
                        </div>
                        <h1 class="text-3xl font-bold text-gray-900 mb-2">@Model.Title</h1>
                        <p class="text-gray-600 mb-1">by @Model.Instructor</p>
                    </div>
                    <div class="text-right ml-6">
                        <div class="text-3xl font-bold text-primary-600 mb-1">@Model.Price</div>
                        <span class="px-3 py-1 text-xs font-semibold text-gray-700 bg-gray-100 rounded-full">
                            @Model.Level
                        </span>
                    </div>
                </div>

                <!-- Event Details Grid -->
                <div class="grid grid-cols-2 gap-4 mb-6 pb-6 border-b border-gray-200">
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-calendar text-primary-600 mr-2 w-5"></i>
                        <span>@Model.Date.ToString("MMMM dd, yyyy")</span>
                    </div>
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-clock text-primary-600 mr-2 w-5"></i>
                        <span>@Model.Time.ToString(@"hh\:mm")</span>
                    </div>
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-hourglass-half text-primary-600 mr-2 w-5"></i>
                        <span>@Model.Duration</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <div class="flex items-center text-sm text-gray-600">
                            <i class="fas fa-map-marker-alt text-primary-600 mr-2 w-5"></i>
                            <span>@Model.Location</span>
                        </div>
                    }
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-users text-primary-600 mr-2 w-5"></i>
                        <span>@Model.Participants/@Model.MaxParticipants participants</span>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex items-center gap-3 flex-wrap">
                    @if (!string.IsNullOrEmpty(userEmail))
                    {
                        @if (ViewBag.IsRegistered == true)
                        {
                            {
                                var statusClass = ViewBag.RegistrationStatus == "Completed" ? "bg-primary-100 text-primary-700" : "bg-green-100 text-green-700";
                            }
                            <span class="px-4 py-2 text-sm font-semibold rounded-lg">
                                @ViewBag.RegistrationStatus
                            </span>
                        }
                        else if (ViewBag.IsEventFull == true)
                        {
                            <button disabled 
                                    class="px-4 py-2 bg-gray-300 text-gray-600 rounded-lg font-medium cursor-not-allowed">
                                <i class="fas fa-calendar-times mr-2"></i>Event Full
                            </button>
                        }
                        else
                        {
                            <a asp-action="Register" asp-route-eventId="@Model.Id" 
                               class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                                <i class="fas fa-calendar-plus mr-2"></i>Register Now
                            </a>
                        }
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" 
                           class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium inline-flex items-center">
                            <i class="fas fa-sign-in-alt mr-2"></i>Log in to Register
                        </a>
                    }
                    
                    <a asp-action="Index" 
                       class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium inline-flex items-center">
                        <i class="fas fa-arrow-left mr-2"></i>Back to Events
                    </a>
                    
                    @if (userRole == "Admin" || userRole == "Instructor")
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" 
                           class="px-4 py-2 border border-primary-300 text-primary-600 rounded-lg hover:bg-primary-50 transition-colors font-medium inline-flex items-center">
                            <i class="fas fa-edit mr-2"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" 
                           class="px-4 py-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 transition-colors font-medium inline-flex items-center">
                            <i class="fas fa-trash mr-2"></i>Delete
                        </a>
                    }
                </div>
            </div>

            <!-- Description Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Description</h2>
                <p class="text-gray-600 leading-relaxed">@Model.Description</p>
            </div>

            <!-- Agenda Card -->
            @if (Model.Agenda != null && Model.Agenda.Any())
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <h2 class="text-xl font-semibold text-gray-900 mb-4">What You'll Learn</h2>
                    <ul class="space-y-2">
                        @foreach (var item in Model.Agenda)
                        {
                            <li class="flex items-start text-gray-700">
                                <i class="fas fa-check-circle text-green-500 mr-3 mt-1 flex-shrink-0"></i>
                                <span>@item</span>
                            </li>
                        }
                    </ul>
                </div>
            }

            <!-- Materials Card -->
            @if (Model.Materials != null && Model.Materials.Any())
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <h2 class="text-xl font-semibold text-gray-900 mb-4">Materials Included</h2>
                    <ul class="space-y-2">
                        @foreach (var material in Model.Materials)
                        {
                            <li class="flex items-start text-gray-700">
                                <i class="fas fa-file-alt text-primary-600 mr-3 mt-1 flex-shrink-0"></i>
                                <span>@material</span>
                            </li>
                        }
                    </ul>
                </div>
            }

            <!-- Tags Card -->
            @if (Model.Tags != null && Model.Tags.Any())
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <h2 class="text-xl font-semibold text-gray-900 mb-4">Tags</h2>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="px-3 py-1 text-sm font-medium text-gray-700 bg-gray-100 rounded-full">
                                @tag
                            </span>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Quick Info Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Event Information</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-1">Type</p>
                        <p class="text-gray-900">@Model.Type</p>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-1">Format</p>
                        <p class="text-gray-900">@Model.Format</p>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-1">Level</p>
                        <p class="text-gray-900">@Model.Level</p>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-1">Price</p>
                        <p class="text-gray-900 font-semibold">@Model.Price</p>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-1">Capacity</p>
                        <p class="text-gray-900">@Model.Participants/@Model.MaxParticipants</p>
                    </div>
                </div>
            </div>

            <!-- Instructor Card -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Instructor</h3>
                <div class="flex items-center space-x-3">
                    <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-user text-primary-600"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900">@Model.Instructor</p>
                        <p class="text-sm text-gray-600">Event Facilitator</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Copy share link functionality could be added here
        });
    </script>
}
