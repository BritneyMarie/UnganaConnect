@model UnganaConnect.Frontend.Models.Event
@{
    ViewData["Title"] = "Delete Event";
}

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Delete Event</h1>
        <p class="text-gray-600">Are you sure you want to delete this event?</p>
    </div>

    <!-- Warning Card -->
    <div class="bg-red-50 border border-red-200 rounded-xl p-6 mb-6">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <i class="fas fa-exclamation-triangle text-red-600 text-2xl"></i>
            </div>
            <div class="ml-3">
                <h3 class="text-lg font-semibold text-red-900 mb-2">Warning: This action cannot be undone</h3>
                <p class="text-red-700">This will permanently delete the event "@Model.Title" and all associated registrations.</p>
            </div>
        </div>
    </div>

    <!-- Event Info Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Event Details</h3>
        <div class="space-y-3">
            <div class="flex items-center">
                <span class="text-sm font-medium text-gray-700 w-32">Title:</span>
                <span class="text-gray-900">@Model.Title</span>
            </div>
            <div class="flex items-center">
                <span class="text-sm font-medium text-gray-700 w-32">Type:</span>
                <span class="text-gray-900">@Model.Type</span>
            </div>
            <div class="flex items-center">
                <span class="text-sm font-medium text-gray-700 w-32">Date:</span>
                <span class="text-gray-900">@Model.Date.ToString("MMMM dd, yyyy")</span>
            </div>
            <div class="flex items-center">
                <span class="text-sm font-medium text-gray-700 w-32">Instructor:</span>
                <span class="text-gray-900">@Model.Instructor</span>
            </div>
            <div class="flex items-center">
                <span class="text-sm font-medium text-gray-700 w-32">Participants:</span>
                <span class="text-gray-900">@Model.Participants/@Model.MaxParticipants</span>
            </div>
        </div>
    </div>

    <!-- Delete Form -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <form asp-action="Delete" method="post" class="space-y-6">
            <input type="hidden" asp-for="Id" />
            
            <div class="flex items-center justify-end space-x-4">
                <a asp-action="Index" 
                   class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-times mr-2"></i>Cancel
                </a>
                <button type="submit" 
                        class="px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium inline-flex items-center">
                    <i class="fas fa-trash mr-2"></i>Delete Event
                </button>
            </div>
        </form>
    </div>
</div>
